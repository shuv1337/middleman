{
  "name": "shuvlr",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.1",
  "type": "module",
  "workspaces": [
    "apps/backend",
    "apps/ui",
    "apps/site"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names backend,ui \"pnpm --filter @shuvlr/backend dev\" \"pnpm --filter @shuvlr/ui dev -- --host ${SHUVLR_HOST:-$(node --env-file-if-exists=.env -p 'process.env.SHUVLR_HOST || \"127.0.0.1\"' 2>/dev/null)}\"",
    "dev:backend": "pnpm --filter @shuvlr/backend dev",
    "dev:ui": "pnpm --filter @shuvlr/ui dev -- --host ${SHUVLR_HOST:-$(node --env-file-if-exists=.env -p 'process.env.SHUVLR_HOST || \"127.0.0.1\"' 2>/dev/null)}",
    "dev:site": "pnpm --filter @shuvlr/site dev",
    "build": "pnpm --filter @shuvlr/backend build && pnpm --filter @shuvlr/ui build && pnpm --filter @shuvlr/site build",
    "prod": "pnpm build && pnpm prod:start",
    "prod:start": "concurrently --kill-others-on-fail --names backend,ui \"NODE_ENV=production SHUVLR_PORT=47287 pnpm --filter @shuvlr/backend start\" \"pnpm --filter @shuvlr/ui preview -- --port 47289 --strictPort --host ${SHUVLR_HOST:-$(node --env-file-if-exists=.env -p 'process.env.SHUVLR_HOST || \"127.0.0.1\"' 2>/dev/null)}\"",
    "prod:daemon": "node scripts/prod-daemon.mjs",
    "prod:restart": "node scripts/prod-daemon-restart.mjs",
    "test": "pnpm --filter @shuvlr/backend test && pnpm --filter @shuvlr/ui test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
